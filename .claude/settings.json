{
  "$comment": [
    "Team-curated Claude Code settings for uclaw. Checked in.",
    "Machine-local overrides go in .claude/settings.local.json (gitignored).",
    "Hook scripts mirror scripts/git-hooks/checks/ but run at edit time inside",
    "Claude Code — faster feedback than waiting for git commit.",
    "See BEHAVIOR.md §9 (Hooks Enforce What Spec Says) for policy."
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/check-memory-graph.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/check-uclaw-home.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/check-codex-spdx.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/warn-dmz-edit.sh", "timeout": 5 }
        ]
      }
    ]
  }
}
