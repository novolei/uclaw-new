{
  "id": "browser.auth_profile.restore",
  "title": "Apply an authorized browser profile before navigation",
  "capability": "auth_profile_restore",
  "prompt": "Use an authorized browser profile to open the protected fixture and report whether the account is already signed in.",
  "startUrl": "{{fixtureBaseUrl}}/protected",
  "authOrigin": "{{fixtureBaseUrl}}",
  "authStorageState": {
    "cookies": [
      {
        "name": "uclaw_browser_parity_session",
        "value": "fixture-session",
        "domain": "127.0.0.1",
        "path": "/"
      }
    ],
    "origins": [
      {
        "origin": "{{fixtureBaseUrl}}",
        "localStorage": [
          {
            "name": "uclawBrowserParity",
            "value": "signed-in"
          }
        ]
      }
    ]
  },
  "maxSteps": 8,
  "expectedStatus": "completed",
  "requiredActions": ["browser_auth_profile_apply", "browser_navigate"],
  "expectedUrlContains": "{{fixtureBaseUrl}}/protected",
  "requireAuthBeforeNavigation": true,
  "maxActionCount": 6
}
