# gbrain source clone (downloaded by setup-gbrain-source.sh)
# gbrain Sprint 2.0 — clone of github.com/garrytan/gbrain with bun-install'd
# node_modules. Bundled as Tauri resource; spawned at runtime via bunembed/bun.
src-tauri/gbrain-source

# Rust build artifacts
src-tauri/target/
# Workspace root build artifacts (post Phase 0.5-T2)
/target/

# Frontend
# 不带尾斜杠 — 同时捕获目录和 git worktree 创建的 symlink
ui/node_modules
ui/.env
ui/.env.local

# Build output (Tauri serves this from static/)
static/

# Tauri generated files
src-tauri/gen/

# Local runtime data
src-tauri/data/

# AI-generated repo wiki (Qoder)
.qoder/

# Root package-lock (not a package.json project)
package-lock.json

# macOS
.DS_Store
**/.DS_Store

# Editor
.idea/
